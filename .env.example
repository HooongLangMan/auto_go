APP_ENV=dev
APP_TIMEZONE=Asia/Shanghai
SELECTION_COUNT=3
RUN_DRY=true
PUBLISH_ENABLED=false
WECHAT_PUBLISH_ENABLED=false
XHS_PUBLISH_ENABLED=false
WECHAT_AUTO_PUBLISH=false

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=auto_football
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
DATABASE_URL=

REDIS_URL=redis://localhost:6379/0
FIXTURE_CACHE_TTL_SECONDS=86400
CONTEXT_CACHE_TTL_SECONDS=259200
SOURCE_DOC_CACHE_TTL_SECONDS=604800

API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_KEY=

PUBLIC_FIXTURE_API_URL=https://688zb40.com/api/Football/all_match

THESPORTSDB_API_URL=https://www.thesportsdb.com/api/v1/json
THESPORTSDB_API_KEY=

CLUBELO_API_URL=http://api.clubelo.com
CLUBELO_ENABLED=true
OPENFOOTBALL_ENABLED=true
STATSBOMB_ENABLED=false
STATSBOMB_COMPETITION_SCAN_LIMIT=12
FBREF_ENABLED=false
FBREF_BROWSER_PATH=C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe
FBREF_HEADLESS=true
WHOSCORED_ENABLED=false
WHOSCORED_BROWSER_PATH=C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe
WHOSCORED_HEADLESS=true
FOOTBALL_DATA_API_URL=https://api.football-data.org/v4
FOOTBALL_DATA_API_KEY=
FOOTBALL_DATA_RATE_LIMIT_PER_MINUTE=9

LLM_BASE_URL=https://api.deepseek.com
LLM_CHAT_PATH=/chat/completions
LLM_API_KEY=
LLM_MODEL=deepseek-chat

WECHAT_MCP_COMMAND=python
WECHAT_MCP_ARGS_JSON=["-m","wechat_oa_api_mcp","--port","8123"]
WECHAT_MCP_WORKDIR=
WECHAT_OA_ACCOUNT=
WECHAT_OA_PASSWORD=
# Keep your current outbound IPs in the WeChat OA API whitelist.
# Example:
# 14.155.134.173
# 14.155.252.249
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_AUTHOR=Auto Football

XHS_BROWSER_PATH=
XHS_DEFAULT_TAGS=足球,比赛分析
XHS_DRAFT_ONLY=true
XHS_AUTOMATION_BACKEND=playwright

AI_IMAGE_ENABLED=false
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_API_KEY=
ARK_IMAGE_MODEL=doubao-seedream-4-5-251128
AI_IMAGE_DAILY_LIMIT=6
AI_IMAGE_PER_MATCH_LIMIT=1
WECHAT_INLINE_AI_IMAGE_LIMIT=1

IMAGE_OUTPUT_DIR=generated/images
CONTENT_TARGETS_JSON=[{"account_id":"wechat-main","platform":"wechat","quota":2,"modes":["pre_match","result_flash","hot_recap"]},{"account_id":"xhs-main","platform":"xiaohongshu","quota":3,"modes":["pre_match","result_flash","hot_recap"]}]
